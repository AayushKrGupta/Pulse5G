{
  "expo": {
    "name": "Pulse5G",
    "slug": "Pulse5G",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/5g-icon.png",
    "scheme": "pulse5g",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#151718",
        "foregroundImage": "./assets/images/5g-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/5g-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#151718"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
